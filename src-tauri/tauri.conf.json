{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PP18 Video Tools",
  "version": "0.1.1",
  "identifier": "local.pp18.video-tools",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PP18 Video Tools",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "bin/*": "bin/"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEExMjkxRkIxQkM0RUU1OTIKUldTUzVVNjhzUjhwb1lrRXZqdmt3K0tKWXJKbm11MWhFMkRwN3NyVGp2TkwzeGM5Tmx3S3ZnVTQK",
      "endpoints": [
        "https://github.com/ayurash77/pp18-video-tools_tauri/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
